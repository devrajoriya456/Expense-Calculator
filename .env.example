# ---------------------------------------------------------------------------
# Copy this file to `.env` (local) or set these in your host's env manager
# (Vercel, etc.). NEVER commit real secrets. Rotate any key that has leaked.
# ---------------------------------------------------------------------------

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key
# Server-only. Bypasses RLS — must never be exposed to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# NextAuth
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=replace-with-a-strong-random-secret
# The full canonical URL of the deployed app (used for auth callbacks + invites).
NEXTAUTH_URL=https://your-domain.com
NEXT_PUBLIC_APP_URL=https://your-domain.com

# Google OAuth (https://console.cloud.google.com/apis/credentials)
GOOGLE_ID=your-google-oauth-client-id
GOOGLE_SECRET=your-google-oauth-client-secret

# Postgres (only if you connect directly; the app uses Supabase client)
DATABASE_URL=postgresql://user:password@host:5432/postgres

# SMTP for invitation emails (optional — invites won't email if unset)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Trip Split <no-reply@your-domain.com>"

# Set to "production" when deployed
NODE_ENV=development
